{
  "version": "0.2.0",
  "description": "Use this debug config with helper-scripts/run_test_thing.py along with command line arguments", 
  "configurations": [
    {
      "name": "Python: Debug Current File (WITH args prompt)",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": false,
      "args": ["${input:programArgs}"]
    },
    {
      "name": "Python: Debug Current File (WITHOUT args prompt)",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": false,
    },
    {
      "name": "Python: Attach to debugpy",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
    }
  ],
  "inputs": [
    {
      "id": "programArgs",
      "type": "promptString",
      "description": "Command-line arguments to pass (space-separated)",
      "default": ""
    }
  ]
}
